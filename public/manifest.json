{
  "manifest_version": 3,
  "name": "Aliasify",
  "version": "1.0.0",
  "description": "A local URL shortener - create and manage personal go/ shortcuts for frequently used URLs",
  "action": {
    "default_popup": "index.html",
    "default_title": "Aliasify"
  },
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
